<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ name }} - Device Inventory</title>
{% include 'inventory-html/_styles.css' %}
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>{{ name }}</h1>
            <p>Device Inventory Report</p>
        </div>

        <div class="controls">
            <div class="search-wrapper">
                <input type="text"
                       class="search-box"
                       id="searchInput"
                       placeholder="Search by device name, role, site, location, rack, platform, vendor, or model..."
                       onkeyup="handleSearchInput(event)">
                <button class="clear-search" id="clearSearch" onclick="clearSearch()" title="Clear search">×</button>
            </div>
            <div class="filters-group">
                <div class="filter-section">
                    <span class="filter-label">Site:</span>
                    <div class="location-buttons" id="siteButtons">
                        <button class="location-btn active" onclick="filterBySite('')">All</button>
                    </div>
                </div>
                <div class="filter-section">
                    <span class="filter-label">Location:</span>
                    <div class="location-buttons" id="locationButtons">
                        <button class="location-btn active" onclick="filterByLocation('')">All</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-container">
            <table id="inventoryTable">
{% include 'inventory-html/_table_header.html' %}
                <tbody>
{% for node in rendered_nodes -%}
{{ node }}
{%- endfor %}
                </tbody>
            </table>
        </div>

        <div class="footer">
            NetBox Device Inventory Report
        </div>
    </div>

{% include 'inventory-html/_modal.html' %}
{% include 'inventory-html/_scripts.js' %}
</body>
</html>
